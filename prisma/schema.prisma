generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id      String   @id @default(cuid())
  email   String   @unique
  name    String?
  image   String?
  isAdmin Boolean  @default(false)
  phone   String?
  station String?
  tickets Ticket[]
}

model Ticket {
  id           String             @id @default(cuid())
  ticketNumber Int                @default(autoincrement()) @unique
  assignedTo   String             @default("helpdesk@cristalino.co.il")
  subject      String
  description  String
  phone        String
  computerName String
  urgency      String             @default("בינוני")
  category     String             @default("אחר")
  platform     String             @default("מחשב אישי")
  status       String             @default("פתוח")
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  userId       String
  user         User               @relation(fields: [userId], references: [id])
  // For email-ingested tickets: the source email's Message-ID. Unique so the
  // same email can never create two tickets (idempotency). Null for UI tickets.
  sourceMessageId String?         @unique
  // Free-text reason required when staff places a ticket on hold ("בהמתנה").
  // Cleared automatically when the ticket is reinstated.
  holdReason      String?
  notes        TicketNote[]
  attachments  TicketAttachment[]
  messages     TicketMessage[]
  review       TicketReview?
  history      TicketHistory[]

  // userId — user dashboard filters by owner; status — digest/sweep crons
  // filter by it every few minutes. Postgres does not auto-index FKs.
  @@index([userId])
  @@index([status])
}

model TicketHistory {
  id          String   @id @default(cuid())
  ticketId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  field       String   // "created" | "status" | "urgency" | "assignedTo" | "edited"
  oldValue    String?
  newValue    String?
  actorName   String
  actorEmail  String
  changedAt   DateTime @default(now())

  @@index([ticketId])
}

model TicketMessage {
  id          String   @id @default(cuid())
  ticketId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  content     String
  authorName  String
  authorEmail String
  authorRole  String   // "staff" | "user"
  createdAt   DateTime @default(now())

  @@index([ticketId])
}

model TicketNote {
  id          String   @id @default(cuid())
  ticketId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  content     String
  authorName  String
  authorEmail String
  createdAt   DateTime @default(now())

  @@index([ticketId])
}

// Attachment bytes live on the server filesystem (uploads/ticket-attachments/)
// since v3.48 — like printer drivers, the DB holds only metadata. `dataUrl`
// remains for legacy rows uploaded before the change (served via fallback,
// migrated to disk by scripts/migrate-attachments-to-disk.js).
model TicketAttachment {
  id         String   @id @default(cuid())
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  dataUrl    String?  // legacy inline base64 (pre-v3.48); null once stored on disk
  storedName String?  @unique // unique on-disk filename (uuid.ext)
  mimeType   String?
  size       Int?     // decoded size in bytes
  filename   String?
  createdAt  DateTime @default(now())

  @@index([ticketId])
}

model TicketReview {
  id             String   @id @default(cuid())
  ticketId       String   @unique
  ticket         Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  rating         Int      // 1–5
  comment        String?
  submitterName  String
  submitterEmail String
  createdAt      DateTime @default(now())
}

model License {
  id        String   @id @default(cuid())
  key       String   // the license number / product key
  category  String   @default("Office") // managed via FieldOption (field = "licenseCategory")
  username  String?  // optional: account the license was activated with / given to
  password  String?
  remark    String?  // free-text note (e.g. who received it, which machine)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, key])
  @@index([category])
}

model Printer {
  id        String          @id @default(cuid())
  name      String          // display name of the printer
  maker     String?         // יצרן — manufacturer (HP, Canon, Brother...)
  model     String?         // model number / name
  supplier  String?         // ספק — supplier the printer belongs to
  ipv4      String?         // network IPv4 address
  hostname  String?         // network hostname
  inkToner       String?     // סוג דיו/טונר — required ink/toner type
  tonerLevel     Int?        // 0–100 percentage of toner/ink remaining
  supplierSerial String?     // מספר ספק — serial number assigned by the supplier
  createdAt  DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  drivers   PrinterDriver[]

  @@index([name])
}

// Driver files are stored on the server filesystem (uploads/printer-drivers/),
// NOT in the DB — printer drivers can be large binaries. This table holds only
// the metadata; `storedName` is the unique on-disk filename.
model PrinterDriver {
  id         String   @id @default(cuid())
  printerId  String
  printer    Printer  @relation(fields: [printerId], references: [id], onDelete: Cascade)
  filename   String   // original filename shown to the user
  storedName String   @unique // unique name on disk (uuid + sanitized original)
  size       Int      // file size in bytes
  mimeType   String?
  createdAt  DateTime @default(now())

  @@index([printerId])
}

model FieldOption {
  id    String @id @default(cuid())
  field String // "category" | "platform" | "urgency"
  label String
  order Int    @default(0)

  @@unique([field, label])
  @@index([field])
}

model Log {
  id        String   @id @default(cuid())
  timestamp DateTime @default(now())
  level     String   @default("error")
  message   String
  source    String?
  stack     String?
  date      String

  // Admin logs tab filters by date and always orders by timestamp desc.
  @@index([date])
  @@index([timestamp])
}
